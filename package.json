{
  "name": "soka-baru",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @soka/api test",
    "validate": "pnpm test && pnpm typecheck && pnpm --filter @soka/web build",
    "check:env": "node scripts/check-env.mjs",
    "smoke:live": "node scripts/live-smoke.mjs",
    "dev:api": "pnpm --filter @soka/api dev",
    "dev:web": "pnpm --filter @soka/web dev",
    "db:generate": "pnpm --filter @soka/db generate",
    "db:migrate": "pnpm --filter @soka/db migrate",
    "db:seed": "pnpm --filter @soka/db seed"
  }
}
