# SOKA Baru — local development environment variables.
# Copy to .env and fill in. Never commit real secrets.

# Postgres connection string (Neon or local Postgres).
DATABASE_URL=postgres://user:password@localhost:5432/soka

# Better Auth — generate a long random string for local dev.
BETTER_AUTH_SECRET=replace-with-a-long-random-string
BETTER_AUTH_URL=http://localhost:8787

# Web origin allowed to call the API (comma-separated).
WEB_ORIGIN=http://localhost:5173

# API server port.
PORT=8787
