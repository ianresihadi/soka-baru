# SOKA Baru — local development environment variables.
# Copy to .env and fill in with REAL values. Never commit real secrets (.env is
# gitignored). Run `pnpm check:env` to validate before the live path.

# Postgres connection string (Neon or local Postgres). REQUIRED for the live path.
DATABASE_URL=postgres://user:password@localhost:5432/soka

# Better Auth — REQUIRED. Use a long random string (>= 16 chars) for local dev.
BETTER_AUTH_SECRET=replace-with-a-long-random-string
BETTER_AUTH_URL=http://localhost:8787

# Web origin allowed to call the API (comma-separated). REQUIRED.
WEB_ORIGIN=http://localhost:5173

# API server port. Optional (defaults to 8787).
PORT=8787

# Optional: base URLs used by `pnpm smoke:live`.
# SOKA_API_URL defaults to http://localhost:8787; SOKA_WEB_URL to http://localhost:5173.
# SOKA_API_URL=http://localhost:8787
# SOKA_WEB_URL=http://localhost:5173
